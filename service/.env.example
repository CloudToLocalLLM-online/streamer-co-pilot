# Platform config
PLATFORM=twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
BOT_ID=
CHANNEL_NAME=

# Backend port
TWITCH_BOT_PORT=8510

# StreamElements
STREAMELEMENTS_JWT_TOKEN=
STREAMELEMENTS_ACCOUNT_ID=

# StreamLabs
STREAMLABS_ACCESS_TOKEN=

# Alert defaults
ALERT_DURATION_SECONDS=8
ALERT_SOUND_ENABLED=true
ALERT_TTS_ENABLED=true
ALERT_TTS_VOICE=en-US-JennyNeural

# SSE/event defaults
SSE_RECONNECT_DELAY=5